rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: teachers/{nip}/students
    // Fields: id, name, className, nis, nisn, etc.
    //
    // Collection: teachers/{nip}/logs
    // Fields: id, studentId, date, type, aspect, result, etc.
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() && 
        (request.auth.token.email == "PURNOMOWIWIT@gmail.com" && request.auth.token.email_verified == true);
    }

    function isOwner(nip) {
      return isAuthenticated() && (request.auth.uid == nip || isAdmin());
    }

    function isValidStudent(data) {
      return data.keys().hasAll(['id', 'name', 'className']) &&
             data.id is string && data.id.size() > 0 && data.id.size() < 100 &&
             data.name is string && data.name.size() > 0 && data.name.size() < 100 &&
             data.className is string && data.className.size() > 0 && data.className.size() < 50;
    }

    function isValidLog(data) {
      return data.keys().hasAll(['id', 'studentId', 'date']) &&
             data.id is string && data.id.size() > 0 && data.id.size() < 100 &&
             data.studentId is string && data.studentId.size() > 0 && data.studentId.size() < 100 &&
             data.date is string && data.date.size() > 0;
    }

    function isValidNotification(data) {
      return data.keys().hasAll(['id', 'userId', 'title', 'message', 'type']) &&
             data.id is string && data.id.size() > 0 && data.id.size() < 100 &&
             data.userId is string && data.userId.size() > 0 && data.userId.size() < 100 &&
             data.title is string && data.title.size() > 0 && data.title.size() < 200 &&
             data.message is string && data.message.size() > 0 && data.message.size() < 1000 &&
             data.type is string && data.type.size() > 0 && data.type.size() < 50;
    }

    function uidNotModified() {
      return !('uid' in request.resource.data) || request.resource.data.uid == resource.data.uid;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /teachers/{nip} {
      allow read, write: if isOwner(nip);

      match /profile/data {
        allow read: if true; // Allow anyone to read the teacher's public profile (name, phone, etc.)
        allow write: if isOwner(nip);
      }

      match /students/{studentId} {
        allow read: if true; // Allow students to find their names
        allow create: if isOwner(nip) && isValidStudent(request.resource.data);
        allow update: if isOwner(nip) && isValidStudent(request.resource.data) && uidNotModified();
        allow delete: if isOwner(nip);
      }

      match /akpd/{akpdId} {
        allow read: if isOwner(nip);
        allow create: if true; // Allow students to submit AKPD
        allow update, delete: if isOwner(nip);
      }

      match /report_mutations/{reportId} {
        allow read: if isOwner(nip);
        allow create: if true; // Allow students to submit reports
        allow update, delete: if isOwner(nip);
      }

      match /problem_reports/{reportId} {
        allow read: if isOwner(nip);
        allow create: if true; // Allow students to submit problem reports
        allow update, delete: if isOwner(nip);
      }

      match /logs/{logId} {
        allow read: if isOwner(nip);
        allow create: if isOwner(nip) && isValidLog(request.resource.data);
        allow update: if isOwner(nip) && isValidLog(request.resource.data) && uidNotModified();
        allow delete: if isOwner(nip);
      }

      match /notifications/{notificationId} {
        allow read, write: if isOwner(nip) && isValidNotification(request.resource.data);
      }

      match /groups/{groupId} { allow read, write: if isOwner(nip); }
      match /events/{eventId} { allow read, write: if isOwner(nip); }
      match /schedules/{scheduleId} { allow read, write: if isOwner(nip); }
      match /parent_communications/{commId} { allow read, write: if isOwner(nip); }
      match /homeroom_journals/{journalId} { allow read, write: if isOwner(nip); }
      match /sociometry/{id} { allow read, write: if isOwner(nip); }
      match /achievements/{id} { allow read, write: if isOwner(nip); }
      match /violations/{id} { allow read, write: if isOwner(nip); }
      
      // Catch-all for any other collections under the teacher's document
      match /{collection}/{documentId} {
        allow read, write: if isOwner(nip);
      }
    }

    match /public_chat/{msgId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
    }

    match /shared_items/{itemId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update, delete: if isAuthenticated() && (request.auth.uid == resource.data.authorUid || isAdmin());

      match /comments/{commentId} {
        allow read: if isAuthenticated();
        allow create: if isAuthenticated();
      }
    }

    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
